# Per-agent environment variables — copy to `.env` (same directory) and fill in.
# The agent's `just` recipe (e.g. `just <this-agent>`) sources this file before
# launching pi, so any var set here is visible to the pi process and to any
# extension / skill it loads.
#
# This file is checked in. The real `.env` is gitignored.

# ─── Provider overrides ────────────────────────────────────────────────────
# Optional: override the default model / provider baked into settings.json.
# Useful for swapping to a local model for a single agent without editing
# .pi/settings.json.
# PI_PROVIDER=openai
# PI_MODEL=gpt-4o

# ─── Agent-specific credentials ────────────────────────────────────────────
# Tokens for services this agent talks to (Telegram bot, webhooks, custom
# APIs, etc.). Anything you don't want in the tracked settings.json.
# TELEGRAM_BOT_TOKEN=
# CUSTOM_API_KEY=

# ─── Runtime tuning ────────────────────────────────────────────────────────
# PI_OFFLINE=1                # disable startup network calls
# PI_SKIP_VERSION_CHECK=1     # skip the pi.dev version check
# HTTP_PROXY=http://127.0.0.1:7890
