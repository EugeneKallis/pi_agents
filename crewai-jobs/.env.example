# ─── LLM provider: OpenCode Go ──────────────────────────────────────────────
# OpenCode Go is an OpenAI-compatible API. CrewAI uses LiteLLM under the
# hood; the `openai/` prefix on the model name picks the right request
# shape, and base_url reroutes the call to opencode.ai.
#
# Get a key at https://opencode.ai/zen
#
# (Optional) If you omit this env var, the example will try to read
# `opencode-go` from ~/.pi/agent/auth.json — handy for pi_agents users.
OPENCODE_API_KEY=sk-ocg-your-key-here

# Base URL. Don't change unless opencode-go moves.
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Model. Currently available on opencode-go:
#   deepseek-v4-flash   (default — fast, cheap)
#   deepseek-v4-pro     (more capable, ~12x cost)
#   glm-5.1, glm-5.2
#   kimi-k2.6, kimi-k2.7-code
#   mimo-v2.5, mimo-v2.5-pro
#   minimax-m2.7, minimax-m3
#   qwen3.6-plus, qwen3.7-max, qwen3.7-plus
MODEL=deepseek-v4-flash

# ─── News source ─────────────────────────────────────────────────────────────
# Default: BBC News. Try also:
#   https://www.reuters.com
#   https://apnews.com
#   https://www.theguardian.com
#   https://www.aljazeera.com/news
NEWS_URL=https://www.bbc.com/news

# How many top stories the researcher should pull
NEWS_LIMIT=5

# ─── Output ──────────────────────────────────────────────────────────────────
# Where the final summary is written (relative to project root)
OUTPUT_FILE=output/summary.md
JOBSEARCH_OUTPUT=output/jobsearch/summary.md

# ─── Notifications (Telegram or Discord) ────────────────────────────────────
# Job search results can be sent to you automatically.
# Telegram (preferred): set both vars below
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord (fallback): set a webhook URL from channel settings
DISCORD_WEBHOOK_URL=
